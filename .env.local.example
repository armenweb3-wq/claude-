# ── Catalyst marketplace — environment variables ────────────────────────────
# Copy this file to `.env.local` and fill in the values from your Supabase
# project: Supabase Dashboard → Project Settings → API.
#
# Until these are set, the site still runs and shows friendly "connect Supabase"
# placeholders instead of live data.

# Project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# The PUBLIC anon/public key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
