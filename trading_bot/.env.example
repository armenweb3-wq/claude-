# ─────────────────────────────────────────────────────────────
# crypto-trading-bot — environment configuration
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Trading mode: dry_run (default, no real orders) | live
# The bot REFUSES to place real orders unless this is explicitly "live".
TRADING_MODE=dry_run

# ── Bybit ───────────────────────────────────────────────────
# Use testnet first. Mainnet keys should be restricted to the
# permissions you actually need (no withdrawal scope).
BYBIT_TESTNET=true
BYBIT_API_KEY=
BYBIT_API_SECRET=
# Market category: spot | linear (USDT perps) | inverse
BYBIT_CATEGORY=linear

# ── Trading parameters ──────────────────────────────────────
SYMBOLS=BTCUSDT
TIMEFRAME=15            # minutes (Bybit kline interval)
LOOP_INTERVAL_SECONDS=60

# ── Risk controls ───────────────────────────────────────────
RISK_PER_TRADE_PCT=1.0      # % of equity risked per trade
MAX_LEVERAGE=3
MAX_OPEN_POSITIONS=1
STOP_LOSS_PCT=2.0
TAKE_PROFIT_PCT=4.0
DAILY_MAX_LOSS_PCT=5.0      # halt trading after this daily drawdown

# ── Storage (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_bot

# ── Telegram (optional) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── API server ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
